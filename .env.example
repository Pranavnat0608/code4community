# Local secrets only — never commit. See docs/ai-study-setup.md
# Get a key: https://aistudio.google.com/apikey (optional; not deployed to code4community26.web.app by default)
# GEMINI_API_KEY=

# reCAPTCHA v3 site key for Firebase App Check (public). Production default is in scripts/deploy-code4community-gcp.sh
# NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# Same Firebase Web API key as the client (Firebase Console → Project settings). Needed for server
# routes that verify ID tokens. In dev, keys.dev.js is used if this is unset — restart next dev after changes.
NEXT_PUBLIC_FIREBASE_API_KEY=

# Set to 1 to show demo note-set cards on /study (UI preview; optional).
# NEXT_PUBLIC_STUDY_DEMO=1

# Optional: second Gemini refine pass when heuristics detect imbalanced MCQ option lengths (extra cost).
# QUIZ_DISTRACTOR_REFINE_RETRY=1
