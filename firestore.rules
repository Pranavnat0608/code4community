rules_version = '2';

// Copy everything below into Firebase Console → Firestore Database → Rules → Edit rules → Publish

service cloud.firestore {
  match /databases/{database}/documents {

    // Users: each user can read and write only their own document (document id = auth.uid)
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Tool requests (get-started form): anyone can create; admin can read all; users can read only their own (where email matches)
    match /tool_requests/{id} {
      allow create: if true;
      allow read, list: if request.auth != null && (
        request.auth.token.email == 'shail40926@gmail.com' ||
        resource.data.email == request.auth.token.email
      );
      allow update, delete: if false;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
